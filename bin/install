#!/bin/sh

ln -isn $(readlink -f gemrc) ~/.gemrc
ln -isn $(readlink -f gitconfig) ~/.gitconfig
ln -isn $(readlink -f gitignore) ~/.gitignore
ln -isn $(readlink -f irbrc) ~/.irbrc
ln -isn $(readlink -f plugins) ~/.zsh-plugins
ln -isn $(readlink -f git-hooks) ~/.git-hooks

mkdir -p ~/.bin
ln -isn $(readlink -f bin/git-commit-prefix) ~/.bin/git-commit-prefix
ln -isn $(readlink -f bin/git-rebase-editor) ~/.bin/git-rebase-editor

mkdir -p ~/.config
ln -isn $(readlink -f starship.toml) ~/.config/starship.toml
ln -isn $(readlink -f ghostty) ~/.config/ghostty
ln -isn $(readlink -f aerospace) ~/.config/aerospace

mkdir -p ~/.claude/skills
ln -isn $(readlink -f claude/skills/dependabot-prs) ~/.claude/skills/dependabot-prs
ln -isn $(readlink -f claude/skills/gfix) ~/.claude/skills/gfix
ln -isn $(readlink -f claude/skills/pr-feedback) ~/.claude/skills/pr-feedback
ln -isn $(readlink -f claude/skills/pr-pending-feedback) ~/.claude/skills/pr-pending-feedback
ln -isn $(readlink -f claude/skills/rebase) ~/.claude/skills/rebase
ln -isn $(readlink -f claude/skills/remote-diff) ~/.claude/skills/remote-diff
ln -isn $(readlink -f claude/skills/review-queue) ~/.claude/skills/review-queue
ln -isn $(readlink -f claude/skills/standup) ~/.claude/skills/standup
ln -isn $(readlink -f claude/skills/walkthrough) ~/.claude/skills/walkthrough
ln -isn $(readlink -f claude/skills/fix-all) ~/.claude/skills/fix-all

./bin/install-pi

cp -i $(readlink -f zshrc) ~/.zshrc

read -p "Your Name for Git Commits: " git_name

if [[ -n $git_name ]]; then
  read -p "Your Email for Git Commits: " git_email

  echo "" >> ~/.zshrc
  echo "# GIT CONFIG" >> ~/.zshrc
  echo "export GIT_AUTHOR_NAME=\"$git_name\"" >> ~/.zshrc
  echo "export GIT_AUTHOR_EMAIL=\"$git_email\"" >> ~/.zshrc
  echo "export GIT_COMMITTER_NAME=\"$git_name\"" >> ~/.zshrc
  echo "export GIT_COMMITTER_EMAIL=\"$git_email\"" >> ~/.zshrc

  echo "Git Name and Email have been appended to ~/.zshrc"
fi
